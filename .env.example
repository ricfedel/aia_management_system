# ─────────────────────────────────────────────────────────────────────────────
# AIA Management System — Variabili d'ambiente
#
# Istruzioni:
#   cp .env.example .env
#   # Modifica .env con i valori reali (NON committare .env su git)
#
# Generazione segreti:
#   JWT_SECRET:          openssl rand -hex 64
#   AIA_INTERNAL_SECRET: openssl rand -hex 32
#   DB_PASSWORD:         openssl rand -hex 16
# ─────────────────────────────────────────────────────────────────────────────

# ── JWT ───────────────────────────────────────────────────────────────────────
# OBBLIGATORIO — minimo 64 caratteri
JWT_SECRET=CHANGE-THIS-JWT-SECRET-MIN-64-CHARS-USE-OPENSSL-RAND-HEX-64

# Durata token accesso (ms) — default 24h
JWT_EXPIRATION=86400000

# Durata token refresh (ms) — default 7 giorni
JWT_REFRESH_EXPIRATION=604800000

# ── Segreto API interne (BPM self-call) ───────────────────────────────────────
# OBBLIGATORIO — deve corrispondere a app.internal.secret in application.properties
# Nginx lo stripa dalle richieste esterne: proxy_set_header X-Internal-Token ""
# Generare con: openssl rand -hex 32
AIA_INTERNAL_SECRET=CHANGE-THIS-INTERNAL-SECRET-USE-OPENSSL-RAND-HEX-32

# ── Database H2 ───────────────────────────────────────────────────────────────
DB_USERNAME=aia
DB_PASSWORD=CHANGE-THIS-DB-PASSWORD

# ── Porte esposte su host ─────────────────────────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Email (opzionale) ─────────────────────────────────────────────────────────
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_DEFAULT_RECIPIENT=admin@grandimolini.it
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
